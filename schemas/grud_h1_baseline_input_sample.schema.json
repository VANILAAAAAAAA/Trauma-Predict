{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trauma-predict.local/schemas/grud_h1_baseline_input_sample.schema.json",
  "title": "GRU-D H1 Baseline Input Sidecar V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "sample_id", "subject_id", "hadm_id", "stay_id", "sample_key",
    "split", "prediction_hour", "static", "input_geometry", "input_events",
    "input_source_count", "source_reference", "target_reference", "registry",
    "content_hash"
  ],
  "properties": {
    "schema": {"const": "grud_h1_baseline_input_sample_v1"},
    "sample_id": {"type": "string", "minLength": 1},
    "subject_id": {"type": "string", "minLength": 1},
    "hadm_id": {"type": "string", "minLength": 1},
    "stay_id": {"type": "string", "minLength": 1},
    "sample_key": {"type": "string", "minLength": 1},
    "split": {"enum": ["train", "val", "test"]},
    "prediction_hour": {"type": "integer", "minimum": 1, "maximum": 312},
    "static": {"type": "object"},
    "input_geometry": {"$ref": "#/$defs/inputGeometry"},
    "input_events": {
      "type": "array",
      "items": {"$ref": "#/$defs/fiveTuple"}
    },
    "input_source_count": {
      "type": "array",
      "items": {"type": "integer", "minimum": 0}
    },
    "source_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["base_content_hash", "target_content_hash"],
      "properties": {
        "base_content_hash": {"$ref": "#/$defs/sha256"},
        "target_content_hash": {"$ref": "#/$defs/sha256"}
      }
    },
    "target_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sample_id", "contract", "future_blocks", "resolution", "stochastic_factors",
        "target_content_hash", "target_shard_key", "target_line_index"
      ],
      "properties": {
        "sample_id": {"type": "string", "minLength": 1},
        "contract": {"const": "multires_event_m4_target_v2_c4_full_20260714_r9"},
        "future_blocks": {"const": 6},
        "resolution": {"const": "M4"},
        "stochastic_factors": {"const": 414},
        "target_content_hash": {"$ref": "#/$defs/sha256"},
        "target_shard_key": {"type": "string", "minLength": 1},
        "target_line_index": {"type": "integer", "minimum": 0}
      }
    },
    "registry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "registry_version", "resolution", "h1_template_count", "tuple_order", "padding_id"
      ],
      "properties": {
        "registry_version": {"const": "2026-07-12-full-field-v1"},
        "resolution": {"const": "H1"},
        "h1_template_count": {"const": 118},
        "tuple_order": {
          "const": ["field_id", "operator_id", "condition_id", "value", "block_id"]
        },
        "padding_id": {"const": 0}
      }
    },
    "content_hash": {"$ref": "#/$defs/sha256"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "inputGeometry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "resolution", "prediction_hour", "history_start_hour", "history_end_hour",
        "history_hours", "max_history_hours", "block_count", "block_id_semantics"
      ],
      "properties": {
        "resolution": {"const": "H1"},
        "prediction_hour": {"type": "integer", "minimum": 1, "maximum": 312},
        "history_start_hour": {"type": "integer", "minimum": 0},
        "history_end_hour": {"type": "integer", "minimum": 1, "maximum": 312},
        "history_hours": {"type": "integer", "minimum": 1, "maximum": 312},
        "max_history_hours": {"const": 312},
        "block_count": {"type": "integer", "minimum": 1, "maximum": 312},
        "block_id_semantics": {"const": "zero_based_chronological_H1_from_history_start"}
      }
    },
    "fiveTuple": {
      "type": "array",
      "prefixItems": [
        {"type": "integer", "minimum": 1},
        {"type": "integer", "minimum": 1},
        {"type": "integer", "minimum": 1},
        {"type": "number"},
        {"type": "integer", "minimum": 0, "maximum": 311}
      ],
      "items": false,
      "minItems": 5,
      "maxItems": 5
    }
  }
}
